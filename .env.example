# Acadexis Backend Environment Variables

# Core Django Settings
SECRET_KEY=your-django-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# SQLite is used by default in development if DB_URL is not set
DB_URL=postgres://user:password@localhost:5432/acadexis_db

# Redis / Celery / WebSockets
REDIS_URL=redis://localhost:6379/0

# CORS & Frontend URLs
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# Email Delivery (Resend / SMTP)
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
EMAIL_FROM_NAME="Acadexis Support"
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# S3 File Uploads (Optional)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# AI Integrations
OPENAI_API_KEY=

# Google OAuth2 Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
